// Blue Book — schema MVP
// Núcleo: User, Entry (música + emoción + contexto), Follow.
// Extensiones tempranas: Tag taxonomy, EntryReaction (Phase 2-ready), SpotifyCache.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
//  USER
// ============================================================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String? // null si solo login con Spotify (vía Account)
  username     String   @unique // handle público, ej. @anita
  displayName  String
  avatarUrl    String?
  bio          String?  @db.VarChar(160)

  emailVerified DateTime? // null si nunca confirmó email (Auth.js)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth.js (vinculación OAuth — p.ej. Spotify)
  accounts Account[]

  entries      Entry[]
  followers    Follow[]        @relation("followee")
  following    Follow[]        @relation("follower")
  reactions    EntryReaction[]
  spotifyCache SpotifyCache?

  @@index([username])
}

// Cuentas OAuth vinculadas a un User (Spotify ahora; Apple/Google a futuro).
// Estructura definida por @auth/prisma-adapter v2 — no inventar campos.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String // "oauth", "oidc", etc.
  provider          String // "spotify"
  providerAccountId String

  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
//  ENTRY — núcleo del producto: un momento + canción + emoción
// ============================================================================
model Entry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot del track al momento de loggear (NO FK a tabla Songs)
  // Razón: Spotify cambia metadata; queremos preservar lo que el usuario vio.
  spotifyId     String // track id
  trackSnapshot Json // { name, artists[], album, image, durationMs, isrc }

  // Level 1 — siempre presente
  reaction String // emoji unicode (🔥 💔 😭 ✨ 🌙 🌅 ...)

  // Level 2 — opcional (free-form, sugeridos por taxonomy)
  moodTags    String[] @default([])
  contextTags String[] @default([])

  // Level 3 — opcional, capado a 500 chars para forzar brevedad
  reflection String? @db.VarChar(500)

  visibility Visibility @default(PUBLIC)
  listenedAt DateTime? // cuando lo escuchó (si != createdAt)
  createdAt  DateTime  @default(now())

  reactions EntryReaction[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([spotifyId])
  @@index([createdAt(sort: Desc)])
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

// ============================================================================
//  FOLLOW — grafo social
// ============================================================================
model Follow {
  followerId String
  followeeId String
  follower   User   @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User   @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followeeId])
  @@index([followeeId])
}

// ============================================================================
//  TAG TAXONOMY — solo para autosuggest, NO es FK obligatoria
// ============================================================================
model Tag {
  slug       String  @id // "nostalgico", "noche-manejando"
  label      String // "nostálgico", "noche manejando"
  type       TagType
  usageCount Int     @default(0)

  @@index([type, usageCount(sort: Desc)])
}

enum TagType {
  MOOD
  CONTEXT
}

// ============================================================================
//  ENTRY REACTION — Phase 2-ready (likes/reactions a entries de otros)
// ============================================================================
model EntryReaction {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([entryId, userId])
  @@index([entryId])
}

// ============================================================================
//  SPOTIFY CACHE — top tracks/artists/recently played para sugerencias
// ============================================================================
model SpotifyCache {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topTracks      Json
  topArtists     Json
  recentlyPlayed Json
  refreshedAt    DateTime
}
