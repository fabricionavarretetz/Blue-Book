# Copia este archivo a `.env` y rellena los valores.
# `.env` está ignorado por git — nunca lo subas al repositorio.

# =============================================================================
#  Database (Supabase)
# =============================================================================
# DATABASE_URL: connection string CON pooler (puerto 6543). Para queries normales
# en serverless. Toma este valor de Supabase: Project Settings → Database
# → Connection string → URI (Transaction pooler). Reemplaza [YOUR-PASSWORD].
DATABASE_URL=

# DIRECT_URL: connection string SIN pooler (puerto 5432). Usado solo por Prisma
# para migraciones (`prisma migrate dev`). Mismo lugar en Supabase: Connection
# string → URI (Session). Reemplaza [YOUR-PASSWORD].
DIRECT_URL=

# =============================================================================
#  Auth.js (NextAuth)
# =============================================================================
# Genera con:  openssl rand -base64 32
AUTH_SECRET=

# AUTH_URL: en dev local con OAuth (Spotify), conviene fijarlo explícitamente
# para que Auth.js use SIEMPRE el mismo origin y la redirect_uri sea consistente.
# Spotify rechaza http://localhost — usa http://127.0.0.1.
# En producción Vercel inyecta esto automáticamente.
AUTH_URL=http://127.0.0.1:3000
AUTH_TRUST_HOST=true

# =============================================================================
#  Spotify Developer App (Blue Book)
# =============================================================================
# Cliente OAuth para conectar cuentas de Spotify. Toma de:
# https://developer.spotify.com/dashboard → tu app Blue Book.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
